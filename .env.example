# --- Allegro application credentials (apps.developer.allegro.pl) ---
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=

# Use the sandbox environment while developing (true) or production (false)
ALLEGRO_SANDBOX=true

# Where Allegro redirects after the seller authorizes the app (authorization_code flow).
# Must match the redirect URI registered for the application.
ALLEGRO_REDIRECT_URI=http://localhost:8000/auth/callback

# --- Storage ---
DATABASE_PATH=./data/arbitrage.db

# --- Notifications (optional) ---
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
NOTIFY_SMTP_HOST=
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASSWORD=
NOTIFY_SMTP_FROM=
NOTIFY_SMTP_TO=
